@baseUrl = http://127.0.0.1:8000

###
# Seed script for a freshly reset DB.
# Run top-to-bottom: users -> media -> reviews.

### Create users
POST {{baseUrl}}/user/create
Content-Type: application/json

{
  "username": "alice"
}

